# Supabase project settings — find these in
# Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Google OAuth credentials are configured in the Supabase Dashboard
# (Authentication -> Providers -> Google), not in this app.
# See docs/GOOGLE_AUTH_SETUP.md for the full setup guide.

# Server-side only: powers AI document analysis (never exposed to the browser).
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: override the analysis model (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
