# Supabase project settings — find these in
# Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Google OAuth credentials are configured in the Supabase Dashboard
# (Authentication -> Providers -> Google), not in this app.
# See docs/GOOGLE_AUTH_SETUP.md for the full setup guide.

# Server-side only: powers AI document analysis (never exposed to the browser).
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: override the analysis model (default gpt-4o-mini for text-heavy docs)
# OPENAI_MODEL=gpt-4o-mini
# Optional: model for visual/multimodal document understanding (default gpt-4o)
# OPENAI_VISUAL_MODEL=gpt-4o

# Server-side only — DANGER: bypasses Row Level Security. Used by the
# account deletion API (after verifying the caller's session) and the daily
# reminder cron. Never expose it to the browser or commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-side only: sends deadline reminder emails via Resend (resend.com).
# Without a verified domain, Resend only delivers to your own account email
# and sends from onboarding@resend.dev.
RESEND_API_KEY=re-your-resend-api-key
# Optional: custom sender once your domain is verified in Resend.
# REMINDER_FROM_EMAIL=Guardian <reminders@yourdomain.com>

# Shared secret protecting /api/cron/reminders. Vercel Cron sends it
# automatically as "Authorization: Bearer <value>" when this env var exists.
# Generate any long random string.
CRON_SECRET=your-long-random-secret

# Optional: include extraction diagnostic payload in /api/documents/analyze
# responses (never logs full document text to the server console).
# GUARDIAN_ANALYSIS_DEBUG=1

# Optional: browser + server error reporting via Sentry (sentry.io).
# Without this, the app runs normally and simply does not report errors.
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
